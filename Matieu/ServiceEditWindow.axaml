<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Matieu.Data"
        xmlns:root="clr-namespace:Matieu"
        x:Class="Matieu.ServiceEditWindow"
        x:DataType="root:ServiceEditWindow"
        Title="Редактирование услуги" Width="600" Height="500"
        WindowStartupLocation="CenterOwner" Background="White">

	<Grid Margin="20" ColumnDefinitions="200, *" RowDefinitions="*, Auto">

		<!-- ЛЕВАЯ ЧАСТЬ: ФОТО -->
		<StackPanel Grid.Column="0" Spacing="10">
			<Border BorderBrush="Gray" BorderThickness="1" Width="150" Height="150">
				<Image Name="imgPreview" Stretch="UniformToFill" Source="{Binding PreviewImage}"/>
			</Border>
			<Button Content="Выбрать фото" Click="BtnSelectPhoto_Click" HorizontalAlignment="Center"/>
			<TextBlock Name="txtFileName" FontSize="10" HorizontalAlignment="Center" Foreground="Gray"/>
		</StackPanel>

		<!-- ПРАВАЯ ЧАСТЬ: ПОЛЯ -->
		<StackPanel Grid.Column="1" Spacing="15">
			<StackPanel>
				<TextBlock Text="Название"/>
				<TextBox Name="txtName" Text="{Binding CurrentService.Name}"/>
			</StackPanel>

			<StackPanel>
				<TextBlock Text="Описание"/>
				<TextBox Name="txtDesc" Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                         Text="{Binding CurrentService.Description}"/>
			</StackPanel>

			<StackPanel>
				<TextBlock Text="Цена (руб.)"/>
				<TextBox Name="txtPrice" Text="{Binding CurrentService.Price}"/>
			</StackPanel>

			<Grid ColumnDefinitions="*, *">
				<StackPanel Grid.Column="0" Margin="0,0,5,0">
					<TextBlock Text="Категория"/>
					<ComboBox Name="cbCategory" HorizontalAlignment="Stretch">
						<ComboBoxItem Content="Custom"/>
						<ComboBoxItem Content="Cosplay"/>
					</ComboBox>
				</StackPanel>
				<StackPanel Grid.Column="1" Margin="5,0,0,0">
					<TextBlock Text="Коллекция"/>
					<!-- ИСПРАВЛЕНО: Добавлен ItemTemplate, чтобы не было Matieu.Data.Collection -->
					<ComboBox Name="cbCollection" HorizontalAlignment="Stretch">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="local:Collection">
								<TextBlock Text="{Binding Name}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</StackPanel>
			</Grid>

			<!-- Добавили этот блок, чтобы не было ошибки "lblError не существует" -->
			<TextBlock Name="lblError" Foreground="Red" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
		</StackPanel>

		<!-- КНОПКИ -->
		<StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
			<Button Content="Сохранить" Click="BtnSave_Click" Width="100"
                    Background="Black" Foreground="White" HorizontalContentAlignment="Center"/>
			<Button Content="Отмена" Click="BtnCancel_Click" Width="100" HorizontalContentAlignment="Center"/>
		</StackPanel>
	</Grid>
</Window>